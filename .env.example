# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/planapp_django

# Cache backend: locmem | redis
CACHE_BACKEND=locmem
REDIS_URL=redis://127.0.0.1:6379/0

# Load/dump API secret (optional, only needed for /api/load_dump/)
LOAD_DUMP_SECRET=

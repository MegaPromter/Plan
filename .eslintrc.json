{
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": [
    "eslint:recommended",
    "prettier"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "off",
    "no-undef": "warn",
    "eqeqeq": "warn",
    "no-var": "warn",
    "prefer-const": "warn"
  },
  "globals": {
    "flatpickr": "readonly",
    "Chart": "readonly",
    "gantt": "readonly",
    "Alpine": "readonly",
    "htmx": "readonly"
  },
  "ignorePatterns": [
    "static/lib/",
    "static/vue/",
    "node_modules/"
  ]
}
